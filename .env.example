# Secrets de WoW-Translator-Bot — copier en .env et remplir.
# Aucune de ces valeurs ne doit être commitée.

# Token bot Discord (Discord Developer Portal)
DISCORD_BOT_TOKEN=
# ID du salon Discord surveillé
DISCORD_CHANNEL_ID=
# Webhook Discord où poster les notifications
DISCORD_WEBHOOK_URL=

# Token GitHub (scope repo) pour publier les releases / màj de la blocklist
GITHUB_TOKEN=

# Clé API Google Gemini (https://aistudio.google.com)
GEMINI_API_KEY=

# Mot de passe servant à (dé)chiffrer secrets.enc
WOW_SECRETS_PASSWORD=
